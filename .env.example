# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console - verification meta tag
# Get it from: https://search.google.com/search-console → Add property → HTML tag method
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools - verification meta tag
# Get it from: https://www.bing.com/webmasters → Add site → HTML meta tag method
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# IndexNow API - secret to protect the /api/indexnow endpoint
# Generate a random string and set it here
INDEXNOW_API_SECRET=

# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
